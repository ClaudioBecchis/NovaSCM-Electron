{
  "name": "novascm",
  "version": "3.1.0-beta.1",
  "description": "NovaSCM - Enterprise Deployment & Asset Management",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "start": "electron .",
    "vite": "vite"
  },
  "author": "PolarisCore",
  "license": "PROPRIETARY",
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "it.polariscore.novascm",
    "productName": "NovaSCM",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/**/*"
    ]
  }
}
